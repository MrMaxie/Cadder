<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Cadder.Tray.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Cadder.Tray.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Cadder"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" KeyDown="RootGrid_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Padding="9,0,140,0">
            <Grid
                ColumnSpacing="12"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="PaneToggleButton"
                    AutomationProperties.AutomationId="PanelPaneToggleButton"
                    AutomationProperties.Name="Toggle navigation pane"
                    Width="36"
                    Height="36"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="PaneToggleButton_Click"
                    ToolTipService.ToolTip="Toggle navigation pane">
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        Glyph="&#xE700;" />
                </Button>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <Image
                        Width="24"
                        Height="24"
                        AutomationProperties.AccessibilityView="Raw"
                        Source="Assets/Square44x44Logo.targetsize-24_altform-unplated.png" />
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Cadder"
                        VerticalAlignment="Center" />
                </StackPanel>

                <AutoSuggestBox
                    x:Name="TitleSearchBox"
                    Grid.Column="2"
                    AutomationProperties.AutomationId="PanelTitleSearchBox"
                    AutomationProperties.Name="Search Cadder panel"
                    MaxWidth="560"
                    MinWidth="220"
                    Height="36"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Search... (Ctrl+E)"
                    QueryIcon="Find"
                    QuerySubmitted="TitleSearchBox_QuerySubmitted"
                    SuggestionChosen="TitleSearchBox_SuggestionChosen"
                    TextChanged="TitleSearchBox_TextChanged">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="4" Spacing="1">
                                <TextBlock Text="{Binding Title}" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding Subtitle}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>

                <StackPanel
                    Grid.Column="3"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse
                            x:Name="TitleStatusDot"
                            Width="8"
                            Height="8"
                            VerticalAlignment="Center"
                            AutomationProperties.AccessibilityView="Raw"
                            Fill="{ThemeResource SystemFillColorNeutralBrush}" />
                        <TextBlock
                            x:Name="TitleStatusText"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Loading"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <Border
                        Width="1"
                        Height="14"
                        VerticalAlignment="Center"
                        AutomationProperties.AccessibilityView="Raw"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock
                        x:Name="TitleCountsText"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="0 instances"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>

        <NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            AutomationProperties.AutomationId="PanelNavigationView"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            OpenPaneLength="288"
            PaneDisplayMode="Auto"
            SelectionChanged="RootNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="NavOverview"
                    AutomationProperties.AutomationId="NavOverview"
                    Content="Overview"
                    Tag="Overview">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="NavInstances"
                    AutomationProperties.AutomationId="NavInstances"
                    Content="Instances"
                    Tag="Instances">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="NavDomains"
                    AutomationProperties.AutomationId="NavDomains"
                    Content="Domains"
                    Tag="Domains">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="NavLogs"
                    AutomationProperties.AutomationId="NavLogs"
                    Content="Logs"
                    Tag="Logs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="NavSettings"
                    AutomationProperties.AutomationId="NavSettings"
                    Content="Settings"
                    Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="NavDiagnostics"
                    AutomationProperties.AutomationId="NavDiagnostics"
                    Content="Diagnostics"
                    Tag="Diagnostics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <ContentControl x:Name="ContentHost" />
        </NavigationView>
    </Grid>
</Window>
