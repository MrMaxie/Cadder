<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cadder.Tray.WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Cadder.Tray.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel Spacing="8">
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Text="Cadder daemon" />
            <TextBlock Text="The daemon is running with zero active registrations." />
            <Button
                x:Name="QuitDaemonButton"
                Click="QuitDaemonButton_Click"
                Content="Quit daemon" />
        </StackPanel>
    </Grid>
</Page>
